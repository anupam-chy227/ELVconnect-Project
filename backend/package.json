{
  "name": "elv-connect-backend",
  "version": "1.0.0",
  "description": "ELV CONNECT — Backend API for Integrated Security & ELV Solutions SaaS",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --exit-child src/server.ts",
    "dev:express": "node --watch server.js",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:express": "node server.js",
    "type-check": "tsc --noEmit",
    "test:e2e": "node e2e_validation.js"
  },
  "dependencies": {
    "@sentry/node": "^10.50.0",
    "axios": "^1.7.9",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.4.1",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.5.0",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.6",
    "openai": "^6.35.0",
    "pg": "^8.16.3",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  },
  "keywords": [
    "elv",
    "cctv",
    "invoice",
    "saas",
    "express",
    "mongodb"
  ],
  "author": "ELV CONNECT",
  "license": "ISC",
  "engines": {
    "node": ">=20.0.0"
  }
